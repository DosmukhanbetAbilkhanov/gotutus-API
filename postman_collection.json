				{
					"name": "Get Cities",
					"request": {
						"method": "GET",
						"header": [
							{"key": "Accept", "value": "application/json"},
							{"key": "Accept-Language", "value": "ru"}
						],
						"url": {
							"raw": "{{base_url}}/cities",
							"host": ["{{base_url}}"],
							"path": ["cities"]
						}
