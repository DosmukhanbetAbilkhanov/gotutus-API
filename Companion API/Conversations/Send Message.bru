meta {
  name: Send Message
  type: http
  seq: 4
}

post {
  url: {{base_url}}/conversations/1/messages
  body: json
  auth: inherit
}

headers {
  Accept: application/json
  Content-Type: application/json
  Authorization: Bearer {{token}}
}

body:json {
  {
      "message": "Hello, looking forward to meeting you!"
  }
}

settings {
  encodeUrl: true
}
