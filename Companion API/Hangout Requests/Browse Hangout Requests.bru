meta {
  name: Browse Hangout Requests
  type: http
  seq: 1
}

get {
  url: {{base_url}}/hangout-requests?city_id=2
  body: none
  auth: none
}

params:query {
  city_id: 2
  ~activity_type_id: 1
  ~date: 2026-02-15
  ~page: 1
}

headers {
  Accept: application/json
}

settings {
  encodeUrl: true
  timeout: 0
}
