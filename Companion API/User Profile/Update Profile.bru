meta {
  name: Update Profile
  type: http
  seq: 2
}

put {
  url: {{base_url}}/user
  body: json
  auth: inherit
}

headers {
  Accept: application/json
  Content-Type: application/json
  Authorization: Bearer {{token}}
}

body:json {
  {
      "name": "John Smith",
      "city_id": 2
  }
}

settings {
  encodeUrl: true
}
